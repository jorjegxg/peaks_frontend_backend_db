# Copy to .env in this directory (repo root). Used by docker-compose for backend + frontend.
# For local dev without Docker: copy to peak-backend/.env and peak/.env.local (or symlink).

# --- Database (backend + db service) ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=peak
MYSQL_USER=peak
MYSQL_PASSWORD=

# --- Frontend (build-time: baked into the Next.js bundle) ---
NEXT_PUBLIC_PEAK_BACKEND_URL=http://localhost:3001

# Firebase client (from Firebase Console > Project settings > General)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Backend: Twilio (OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Backend: Firebase Admin (Google sign-in + phone linking) ---
# Paste full JSON (no newlines) from Firebase Console > Service accounts > Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON={}
# Or use a path to the JSON file inside the container:
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
