# Copy to .env and fill in. Used by root docker-compose.yml.

# Database (same values as peak-backend/.env)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=peak
MYSQL_USER=peak
MYSQL_PASSWORD=

# Frontend: API URL the browser will use (default when running compose locally)
# For production (e.g. behind Nginx) set to https://api.cupoane.space
NEXT_PUBLIC_PEAK_BACKEND_URL=http://localhost:3001
