# peaks/.env — single env file for backend, Next.js (via next.config), and Docker Compose.
# --- Database ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
# --- Database URL (for local dev without Docker) --- (KEEP if you use it)
DATABASE_URL=mysql://user:password@localhost:3306/peak

# --- Frontend → backend ---
NEXT_PUBLIC_PEAK_BACKEND_URL=http://localhost:3001

# --- Firebase (Next.js) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_SITE_URL=https://peak-gaming.site

# --- Firebase Admin (backend) — path from repo root, e.g. peak/firebase-service-account.json ---
FIREBASE_SERVICE_ACCOUNT_PATH={"type": "type","project_id": "project_id","private_key_id": "private_key_id","private_key": "private_key","client_email": "","client_id": "108034818054873960271","auth_uri": "https://accounts.google.com/o/oauth2/auth","token_uri": "https://oauth2.googleapis.com/token","auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url": "","universe_domain": "googleapis.com"}
# --- Backend session JWT ---
JWT_SECRET=
ADMIN_PASSWORD=654321

# --- Twilio (OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

#business details
NEXT_PUBLIC_BUSINESS_PHONE=
NEXT_PUBLIC_BUSINESS_STREET=