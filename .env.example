# peaks/.env — single env file for backend, Next.js (via next.config), and Docker Compose.

# --- Database ---
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
DATABASE_URL=mysql://user:password@localhost:3306/peak

# --- Frontend → backend ---
NEXT_PUBLIC_PEAK_BACKEND_URL=http://localhost:3001

# --- Firebase (Next.js) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (backend) — path from repo root, e.g. peak/firebase-service-account.json ---
FIREBASE_SERVICE_ACCOUNT_PATH=peak/firebase-service-account.json

# --- Backend session JWT ---
JWT_SECRET=

# --- Twilio (OTP) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
