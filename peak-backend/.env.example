# MySQL (use either DATABASE_URL or MYSQL_*)
DATABASE_URL=mysql://user:password@localhost:3306/peak

# Or set individually:
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DATABASE=peak
# MYSQL_USER=peak
# MYSQL_PASSWORD=your-password

TWILIO_ACCOUNT_SID=TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=TWILIO_PHONE_NUMBER
FIREBASE_SERVICE_ACCOUNT_JSON={}

# Firebase Admin (required for Google sign-in + phone linking). Use one of:
# Option A: Paste full JSON (no newlines) from Firebase Console > Project settings > Service accounts > Generate new private key
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: Path to the same JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json